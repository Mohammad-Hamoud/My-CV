<style>
  :root {
    --bg: #0a0a0a;
    --surface: #111111;
    --surface2: #181818;
    --border: #222222;
    --accent: #7B9FE0;
    --accent-dim: rgba(123,159,224,0.12);
    --accent-glow: rgba(123,159,224,0.05);
    --text: #EDEDED;
    --text-secondary: #888;
    --text-muted: #444;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Tajawal', sans-serif;
    font-size: 15px;
    line-height: 1.8;
  }

  body.ar { direction: rtl; }

  /* Language Toggle */
  .lang-toggle {
    position: fixed;
    top: 24px;
    right: 24px;
    z-index: 100;
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 100px;
    display: flex;
    overflow: hidden;
  }
  .lang-btn {
    padding: 7px 18px;
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
    border: none;
    background: transparent;
    color: var(--text-secondary);
    transition: all 0.2s;
    font-family: 'Tajawal', sans-serif;
  }
  .lang-btn.active {
    background: var(--accent);
    color: #0a0a0a;
    font-weight: 700;
  }

  /* Hero */
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 80px 64px 80px;
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid var(--border);
  }
  .hero::before {
    content: '';
    position: absolute;
    top: -300px;
    right: -200px;
    width: 700px;
    height: 700px;
    background: radial-gradient(circle, rgba(201,168,76,0.06) 0%, transparent 65%);
    pointer-events: none;
  }
  .hero::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--accent), transparent);
    opacity: 0.4;
  }
  .hero-label {
    font-size: 11px;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 32px;
    font-weight: 500;
  }
  .hero-name {
    font-size: clamp(56px, 9vw, 104px);
    line-height: 1.0;
    color: #fff;
    margin-bottom: 28px;
    letter-spacing: -2px;
    font-weight: 700;
  }
  body.ar .hero-name {
    letter-spacing: 0;
    font-size: clamp(48px, 7vw, 88px);
  }
  .hero-role {
    font-size: 17px;
    color: var(--text-secondary);
    font-weight: 300;
    margin-bottom: 52px;
    max-width: 520px;
    line-height: 1.8;
  }
  .hero-contact {
    display: flex;
    flex-wrap: wrap;
    gap: 28px;
  }
  .contact-item {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 13px;
    color: var(--text-secondary);
    text-decoration: none;
    transition: color 0.2s;
  }
  .contact-item:hover { color: var(--accent); }
  .contact-dot {
    width: 5px; height: 5px;
    border-radius: 50%;
    background: var(--accent);
    flex-shrink: 0;
  }
  .hero-stats {
    position: absolute;
    bottom: 64px;
    right: 64px;
    display: flex;
    gap: 52px;
  }
  body.ar .hero-stats { right: auto; left: 64px; }
  .stat { text-align: right; }
  body.ar .stat { text-align: left; }
  .stat-num {
    font-size: 40px;
    color: var(--accent);
    line-height: 1;
    font-weight: 700;
  }
  .stat-label {
    font-size: 10px;
    color: var(--text-muted);
    letter-spacing: 2px;
    margin-top: 4px;
    text-transform: uppercase;
  }

  /* Sections */
  .section {
    padding: 88px 64px;
    border-bottom: 1px solid var(--border);
  }
  .section-header {
    display: flex;
    align-items: center;
    gap: 24px;
    margin-bottom: 64px;
  }
  .section-title {
    font-size: 28px;
    color: #fff;
    font-weight: 700;
    white-space: nowrap;
  }
  .section-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, var(--border), transparent);
  }
  body.ar .section-line {
    background: linear-gradient(270deg, var(--border), transparent);
  }

  /* Experience */
  .exp-item {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 48px;
    margin-bottom: 64px;
    padding-bottom: 64px;
    border-bottom: 1px solid var(--border);
  }
  .exp-item:last-child { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }
  .exp-meta { padding-top: 4px; }
  .exp-period {
    font-size: 12px;
    color: var(--accent);
    letter-spacing: 1px;
    font-weight: 500;
    margin-bottom: 8px;
  }
  .exp-company {
    font-size: 13px;
    color: var(--text-muted);
    font-weight: 400;
  }
  .exp-title {
    font-size: 19px;
    font-weight: 700;
    color: #fff;
    margin-bottom: 20px;
    line-height: 1.4;
  }
  .exp-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-bottom: 28px;
  }
  .exp-list li {
    font-size: 13px;
    color: var(--text-secondary);
    padding-left: 16px;
    position: relative;
    line-height: 1.6;
  }
  .exp-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 8px;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--accent);
    opacity: 0.6;
  }
  body.ar .exp-list li { padding-left: 0; padding-right: 16px; }
  body.ar .exp-list li::before { left: auto; right: 0; }

  .achievements-label {
    font-size: 10px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 14px;
    font-weight: 500;
  }
  .achievement-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .tag {
    font-size: 12px;
    padding: 5px 14px;
    border-radius: 100px;
    border: 1px solid #2a2a2a;
    color: var(--text-muted);
    background: var(--surface);
    transition: all 0.2s;
  }
  .tag:hover {
    border-color: var(--accent);
    color: var(--accent);
    background: var(--accent-dim);
  }

  /* Skills */
  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(175px, 1fr));
    gap: 12px;
  }
  .skill-item {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 18px 22px;
    font-size: 13px;
    color: var(--text-secondary);
    transition: all 0.2s;
    cursor: default;
  }
  .skill-item:hover {
    border-color: var(--accent);
    color: var(--accent);
    background: var(--accent-dim);
  }

  /* Education */
  .edu-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 20px;
  }
  .edu-item {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 32px;
    transition: border-color 0.2s;
  }
  .edu-item:hover { border-color: var(--accent); }
  .edu-year {
    font-size: 11px;
    color: var(--accent);
    letter-spacing: 2px;
    margin-bottom: 12px;
    font-weight: 500;
  }
  .edu-degree {
    font-size: 15px;
    font-weight: 700;
    color: #fff;
    margin-bottom: 8px;
    line-height: 1.4;
  }
  .edu-institution { font-size: 13px; color: var(--text-secondary); }

  /* Footer */
  footer {
    padding: 44px 64px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  footer span { font-size: 13px; color: var(--text-muted); }
  .footer-accent { color: var(--accent); font-weight: 500; }

  /* Mobile */
  @media (max-width: 768px) {
    .hero, .section { padding: 60px 24px; }
    .hero-stats { position: static; margin-top: 52px; justify-content: flex-start; gap: 36px; }
    body.ar .hero-stats { left: auto; }
    .exp-item { grid-template-columns: 1fr; gap: 16px; }
    footer { padding: 32px 24px; flex-direction: column; gap: 10px; text-align: center; }
    .lang-toggle { top: 16px; right: 16px; }
  }
</style>
</head>
